# GENERAL PORPUSE DATABASE
MONGODB_URI=mongodb://localhost:27017/nxtimer-dev

# GOOGLE - USED FOR AUTH
AUTH_GOOGLE_ID=optional-field-do-not-change-this-text-only-if-you-will-work-with-authentication-related-features
AUTH_GOOGLE_SECRET=optional-field-do-not-change-this-text-only-if-you-will-work-with-authentication-related-features
AUTH_SECRET=optional-field-do-not-change-this-text-only-if-you-will-work-with-authentication-related-features

# SIGN UP - USED FOR WELCOME EMAIL
RESEND_API_KEY=optional-field-do-not-change-this-text-only-if-you-will-work-with-email-related-features

# CLOUDINARY - USED FOR USERS PROFILE PICTURES
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=optional-field-do-not-change-this-text-only-if-you-will-work-with-image-upload-related-features
NEXT_PUBLIC_CLOUDINARY_API_KEY=optional-field-do-not-change-this-text-only-if-you-will-work-with-image-upload-related-features
CLOUDINARY_API_SECRET=optional-field-do-not-change-this-text-only-if-you-will-work-with-image-upload-related-features
CLOUDINARY_URL=cloudinary://<cloudinary_api_key>:<cloudinary_api_secret>@<cloudinary_cloud_name>

# FIREBASE - FEATURES
NEXT_PUBLIC_FIREBASE_EMULATOR=true
NEXT_PUBLIC_PROJECT_ID=nxtimer-dev
NEXT_PUBLIC_REALTIME=https://nxtimer-dev.firebaseio.com
NEXT_PUBLIC_API_KEY=optional-field-do-not-change-this-text-only-if-you-will-work-with-clash-mode-(FIREBASE)
NEXT_PUBLIC_AUTH_DOMAIN=optional-field-do-not-change-this-text-only-if-you-will-work-with-clash-mode-(FIREBASE)
NEXT_PUBLIC_STORAGE_BUCKET=optional-field-do-not-change-this-text-only-if-you-will-work-with-clash-mode-(FIREBASE)
NEXT_PUBLIC_MESSAGING_SENDER_ID=optional-field-do-not-change-this-text-only-if-you-will-work-with-clash-mode-(FIREBASE)
NEXT_PUBLIC_APP_ID=optional-field-do-not-change-this-text-only-if-you-will-work-with-clash-mode-(FIREBASE)

# UPLOADTHING - USED FOR BACKUP USERS DATA
UPLOADTHING_TOKEN=optional-field-do-not-change-this-text-only-if-you-will-work-with-backups-related-features

# DISCORD - USED FOR AUTH
NEXT_PUBLIC_DISCORD_CLIENT_ID=optional-field-do-not-change-this-text-only-if-you-will-work-with-discord-authentication-related-features
AUTH_DISCORD_ID=optional-field-do-not-change-this-text-only-if-you-will-work-with-discord-authentication-related-features
AUTH_DISCORD_SECRET=optional-field-do-not-change-this-text-only-if-you-will-work-with-discord-authentication-related-features

